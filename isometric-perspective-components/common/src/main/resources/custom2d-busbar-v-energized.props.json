            "type": "string",
            "format": "color",
            "default": "#ef4444"
        },
        "energizedRightColor": {
            "type": "string",
            "format": "color",
            "default": "#dc2626"
        },
        "deenergizedLeftColor": {
            "type": "string",
            "format": "color",
            "default": "#94a3b8"
        },
        "deenergizedRightColor": {
            "type": "string",
            "format": "color",
            "default": "#64748b"
        },
        "strokeColor": {
            "type": "string",
            "format": "color",
            "default": "#f87171"
        },
        "deenergizedStrokeColor": {
            "type": "string",
            "format": "color",
            "default": "#cbd5e1"
        },
        "glowColor": {
            "type": "string",
            "format": "color",
