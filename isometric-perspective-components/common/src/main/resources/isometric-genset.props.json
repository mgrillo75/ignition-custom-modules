{
    "type": "object",
    "additionalProperties": false,
    "required": [
        "bodyColor",
        "accentColor",
        "strokeColor",
        "frameColor",
        "cabinetColor",
        "engineBlockColor",
        "exhaustColor",
        "status"
    ],
    "properties": {
        "bodyColor": {
            "type": "string",
            "format": "color",
            "default": "#879BFF",
            "description": "Main genset housing fill color."
        },
        "accentColor": {
            "type": "string",
            "format": "color",
            "default": "#6E82EE",
            "description": "Secondary housing/accent color."
        },
        "strokeColor": {
            "type": "string",
            "format": "color",
            "default": "#4C5B76",
            "description": "Primary line/stroke color."
        },
        "frameColor": {
            "type": "string",
            "format": "color",
            "default": "#26324B",
            "description": "Skid/frame color."
        },
        "cabinetColor": {
            "type": "string",
            "format": "color",
            "default": "#1D2943",
            "description": "Rear alternator/cabinet color."
        },
        "engineBlockColor": {
            "type": "string",
            "format": "color",
            "default": "#D8DFEA",
            "description": "Front light-gray block color."
        },
        "flywheelColor": {
            "type": "string",
            "format": "color",
            "default": "#6072D9",
            "description": "Flywheel/fan color."
        },
        "exhaustColor": {
            "type": "string",
            "format": "color",
            "default": "#C8924A",
            "description": "Exhaust stack color."
        },
        "shadowOpacity": {
            "type": "number",
            "default": 0.18,
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Ground shadow opacity."
        },
        "status": {
            "type": "string",
            "enum": [
                "off",
                "running",
                "fault"
            ],
            "default": "off",
            "description": "Operational state."
        },
        "statusOffColor": {
            "type": "string",
            "format": "color",
            "default": "#A0AEC0"
        },
        "statusRunningColor": {
            "type": "string",
            "format": "color",
            "default": "#22C55E"
        },
        "statusFaultColor": {
            "type": "string",
            "format": "color",
            "default": "#EF4444"
        },
        "label": {
            "type": "string",
            "default": "Genset-401",
            "description": "Primary display label."
        },
        "value": {
            "type": "string",
            "default": "Standby",
            "description": "Secondary value text."
        },
        "showLabel": {
            "type": "boolean",
            "default": true
        },
        "showValue": {
            "type": "boolean",
            "default": true
        },
        "showStatus": {
            "type": "boolean",
            "default": true
        },
        "labelColor": {
            "type": "string",
            "format": "color",
            "default": "#1F2937"
        },
        "valueColor": {
            "type": "string",
            "format": "color",
            "default": "#334155"
        },
        "style": {
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json",
            "default": {
                "classes": ""
            }
        }
    }
}
