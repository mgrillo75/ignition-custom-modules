{
    "type": "object",
    "additionalProperties": false,
    "required": [
        "targetId",
        "label",
        "strokeColor",
        "textColor",
        "backgroundColor",
        "lineWidth",
        "showAnchorRings",
        "ringColor",
        "ringOpacity",
        "style"
    ],
    "properties": {
        "targetId": {
            "type": "string",
            "default": "breakerA"
        },
        "label": {
            "type": "string",
            "default": "521"
        },
        "strokeColor": {
            "type": "string",
            "format": "color",
            "default": "#56c89b"
        },
        "textColor": {
            "type": "string",
            "format": "color",
            "default": "#eef2f7"
        },
        "backgroundColor": {
            "type": "string",
            "format": "color",
            "default": "#111a2d"
        },
        "lineWidth": {
            "type": "number",
            "default": 2,
            "minimum": 1
        },
        "showAnchorRings": {
            "type": "boolean",
            "default": false
        },
        "ringColor": {
            "type": "string",
            "format": "color",
            "default": "#d1d5db"
        },
        "ringOpacity": {
            "type": "number",
            "default": 0.3,
            "minimum": 0,
            "maximum": 1
        },
        "style": {
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json",
            "default": {
                "classes": ""
            }
        }
    }
}
